# ========================================================
# MediCare Healthcare Application - Backend Environment Variables
# ========================================================

# Server details
PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# Database connections
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net
REDIS_URL=redis://127.0.0.1:6379

# Cross-Origin Resource Sharing (CORS) origin
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:5001

# JSON Web Tokens configuration
ACCESS_TOKEN_SECRET=your_access_token_secret_key_change_me_in_prod
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_change_me_in_prod
REFRESH_TOKEN_EXPIRY=7d

# Gemini AI / MediBot configuration
GEMINI_MODEL=gemini-2.5-flash
# A comma-separated list of active API keys to support load balancing / rotation
GEMINI_API_KEYS=key1,key2,key3

# Cashfree PG payment configuration
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENVIRONMENT=SANDBOX

# Google Authentication integration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email dispatch SMTP server details
EMAIL_USER=support@medicare.com
EMAIL_PASS=your_smtp_mailbox_password

# Firebase admin credentials path
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Cloudinary media assets storage details
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Miscellaneous Configs
HOSPITAL_CODE=0001
