# ========================================================
# MediCare Healthcare Application - Frontend Environment Variables
# ========================================================

# Backend API base endpoints
VITE_API_URL=http://localhost:5001/api/v1
VITE_API_BASE_URL=http://localhost:5001

# Google Authentication Integration client key
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Firebase Client SDK Configuration (Patient Registration OTP etc)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# Sentry Error Diagnostics Monitoring (Graceful glassmorphic boundary catching)
VITE_SENTRY_DSN=
